# Copy to .env and fill in for live mode / production.
# Everything has a safe default for local development in mock mode, except
# the database — you need a running Postgres instance (either via
# `docker compose up db` or your own local install) at this address, or
# override DATABASE_URL to point at one you already have.

ENV=development
DATABASE_URL=postgresql://creditbridge:creditbridge@localhost:5432/creditbridge
JWT_SECRET=dev-secret-change-me-in-production
LLM_MODE=mock
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
ALLOWED_ORIGINS=http://localhost:5173
MAX_UPLOAD_BYTES=2097152
